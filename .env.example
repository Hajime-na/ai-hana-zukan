# AI花図鑑 環境設定
# このファイルをコピーして .env を作成し、APIキーを設定してください。
#   cp .env.example .env
#
# OPENAI_API_KEY が未設定でもアプリは起動します。
# APIキーなしの場合、AI販促文・AI修正はローカル固定ロジックで動作します。

OPENAI_API_KEY=your_api_key_here

# 使用するモデルを変更したい場合のみ設定してください（省略可）
# OPENAI_MODEL=gpt-4.1-mini

# ── Slack通知（任意）────────────────────────────────────────────
# SLACK_NOTIFY_ENABLED=true にすると注文保存・ステータス変更時にSlack通知を送ります。
# SLACK_WEBHOOK_URL が未設定、または SLACK_NOTIFY_ENABLED=false の場合は通知しません。
# 通知に失敗しても注文処理は継続します（サーバーログに失敗を記録）。
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_ENABLED=false
